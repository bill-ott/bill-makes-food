---
const { size = '2rem' } = Astro.props;
---

<svg
    aria-hidden="true"
    viewBox="0 0 24 24"
    width={size}
    height={size}
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
>
    <line x1="2" y1="7" x2="22" y2="7" />
    <line x1="2" y1="12" x2="22" y2="12" />
    <line x1="2" y1="17" x2="22" y2="17" />
</svg>