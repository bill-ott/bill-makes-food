---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const blogPosts = [
	{href: '/blog/1', title: 'Blog No. 1', publishDate: '2026-07-21', previewText: 'preview text...'},
	{href: '/blog/2', title: 'Blog No. 2', publishDate: '2026-07-20', previewText: 'preview text...'},
	{href: '/blog/3', title: 'Blog No. 3', publishDate: '2026-07-19', previewText: 'preview text...'},
];

const recipePosts = [
	{href: '/recipes/1', title: 'Recipe No. 1', publishDate: '2026-07-21', previewText: 'preview text...'},
	{href: '/recipes/2', title: 'Recipe No. 2', publishDate: '2026-07-20', previewText: 'preview text...'},
	{href: '/recipes/3', title: 'Recipe No. 3', publishDate: '2026-07-19', previewText: 'preview text...'},
];
---

<Layout>
	<section class="header-section">
		<h1 class="site-title">Bill Makes Food</h1>
		<p class="tagline">Joy in habitual home cooking</p>
		<p class="intro">
			I've gradually developed a lifestyle I call "cooking by default".
			This is where I share what I've learned.
			Maybe you'll find it helpful, even if you don't (yet) love to cook.
		</p>
	</section>
	<div class="home-page-content-wrapper">
		<section class="blog-section">
			<h2 class="content-header">Latest posts</h2>
			<div class="blog-grid">
				{blogPosts.map(post => (
					<PostCard {...post} />
				))}
			</div>
		</section>
		<section class="recipe-section">
			<h2 class="content-header">Featured recipes</h2>
			<div class="recipe-grid">
				{recipePosts.map(post => (
					<PostCard {...post} />
				))}
			</div>
		</section>
	</div>
</Layout>

<style>
	.header-section {
		color: var(--color-text-primary);
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		margin-top: var(--space-md);
	}
	.site-title {
		font-size: var(--font-size-h2);
		font-weight: 500;
		color: var(--color-text-secondary);
		margin: 0;
	}
	.tagline {
		color: var(--color-text-tertiary);
		font-size: var(--font-size-h5);
		margin: 0; /* resets default */
		margin-top: var(--space-sm);
	}
	.intro {
		margin-top: var(--space-lg);
		max-width: 70ch;
	}
	.home-page-content-wrapper {
		margin-top: var(--space-xl);
	}
	.content-header {
		border-top: var(--section-border);
		font-size: var(--font-size-h6);
		padding-top: var(--space-sm);
	}
	.recipe-section {
		margin-top: var(--space-md);
	}
	.blog-grid, .recipe-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
		gap: var(--space-sm);
	}
</style>
