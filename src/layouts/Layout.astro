---
import { Font } from "astro:assets";
const pathname = Astro.url.pathname;
const navLinks = [
	{href: '/blog', label: 'Blog'},
	{href: '/recipes', label: 'Recipes'},
	{href: '/about', label: 'About'},
	{href: '/contact', label: 'Contact'},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Bill Makes Food</title>
		<Font cssVariable="--font-montserrat" />
	</head>
	<body>
		<header class="site-header">
			<div class="home-link-container">
				<!-- logo will go here -->
				<a
					class="home-link"
					href="/"
					aria-current={pathname === "/" ? "page" : undefined}>
					Bill Makes Food
				</a>
			</div>
			<nav class="site-nav">
				<ul class="nav-list">
					{navLinks.map((link) => (
						<li class="nav-list-item">
							<a
								class="nav-link"
								href={link.href}
								aria-current={pathname === link.href ? "page" : undefined}>
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</nav>
		</header>
		<div class="content-wrapper">
			<slot />
		</div>
		<footer>
			<div class="footer-wrapper">
				<p class="copyright">
					© {new Date().getFullYear()} Bill Makes Food. All rights reserved.
				</p>
				<p class="additional-footer-content">
					Additional things I want to say in the footer go here.
				</p>
			</div>
		</footer>
	</body>
</html>

<style>
	*, *::before, *::after {
		box-sizing: border-box;
	}
	:root {
		--default-font: var(--font-montserrat), sans-serif;
		
		/* font sizes (based on Major Third scale) */
		--font-size-h1: 3.815rem;
		--font-size-h2: 3.052rem;
		--font-size-h3: 2.441rem;
		--font-size-h4: 1.952rem;
		--font-size-h5: 1.562rem;
		--font-size-h6: 1.25rem;
		--font-size-p: 1rem;
		--font-size-small: 0.8rem;
		--font-size-x-small: 0.64rem;

		/* spacing */
		--space-xs:  0.5rem;
		--space-sm:  1rem;
		--space-md:  2rem;
		--space-lg:  3rem;
		--space-xl:  5rem;

		/* borders */
		--section-border: .1rem solid var(--color-border);

		/* ---- Raw palette (Japanese traditional colors) ---- */
		--color-off-white: #FDFBF6;  /* warm white */
		--color-more-off-white: #f2ede3;  /* warmer white */
		--color-forest-green: #1F2E22;  /* derived from pistachio, near-black */
		--color-pistachio: #3D5D42;  /* 木賊色 とくさいろ */
		--color-mouse-gray:#97867C;  /* 銀鼠色 ぎんねずみいろ */
		--color-vermillion: #BC2D29;  /* 銀朱色 ぎんしゅいろ */
		--color-sulphur-yellow: #D3B17D;  /* 蒸栗色 むしくりいろ */

		/* ---- Usage: text ---- */
		--color-text-primary: var(--color-forest-green);
		--color-text-secondary: var(--color-pistachio);
		--color-text-tertiary: var(--color-mouse-gray);

		/* ---- Usage: interactive / accent ---- */
		--color-link: var(--color-vermillion);
		--color-accent-primary: var(--color-vermillion);
		--color-accent-secondary: var(--color-pistachio);
		--color-accent-fill: var(--color-sulphur-yellow);

		/* ---- Usage: surfaces ---- */
		--color-background: var(--color-off-white);
		--color-surface: var(--color-more-off-white);

		/* ---- Usage: borders ---- */
		--color-border: color-mix(in srgb, var(--color-sulphur-yellow) 40%, transparent);
		--color-border-strong: var(--color-sulphur-yellow);
		--color-border-stronger: var(--color-mouse-gray);

		font-family: var(--default-font);
		background-color: var(--color-background);
		color: var(--color-text-primary);
	}
	body {
		margin: 0;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		padding: var(--space-md);
	}
	.site-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.home-link {
		color: var(--color-text-secondary);
		text-decoration: none;
	}
	.home-link:hover {
		color: color-mix(in srgb, var(--color-text-secondary) 65%, transparent);
	}
	.nav-link {
		color: var(--color-link);
		text-decoration: none;
	}
	.nav-link:hover {
		color: color-mix(in srgb, var(--color-link) 65%, transparent);
	}
	.nav-list {
		margin: 0;
		padding: 0;
		list-style-type: none;
		display: flex;
		gap: var(--space-lg);
	}
	.content-wrapper {
		flex: 1;
	}
	.footer-wrapper {
		font-size: var(--font-size-small);
		color: var(--color-text-secondary);
		margin-top: var(--space-md);
	}
	.copyright {
		margin: 0;
	}
	.additional-footer-content {
		margin: 0;
	}
</style>
